          </div>
        )}

      </div>

      {/* ── MODALS ── */}
      {modal && modal.type === "new" && (
        <Modal onClose={()=>setModal(null)}>
          <EventForm
            initial={{ title:"", date: modal.date||"", cat:"gen", target:"", note:"" }}
            onSave={handleSave}
            onCancel={()=>setModal(null)}
          />
        </Modal>
      )}

      {modal && modal.type === "edit" && modal.event && (
        <Modal onClose={()=>setModal(null)}>
          <EventForm
            initial={modal.event}
            onSave={handleSave}
            onCancel={()=>setModal(null)}
            onDelete={handleDelete}
          />
        </Modal>
      )}

      {/* Bottom hint */}
      <div style={{
        textAlign:"center", padding:"16px 16px 24px",
        fontSize:11, color:"#bbb",
      }}>
        לחץ על יום בלוח להוספת אירוע · לחץ על אירוע לעריכה · האירועים נשמרים אוטומטית
      </div>
    </div>
  );
}


    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
